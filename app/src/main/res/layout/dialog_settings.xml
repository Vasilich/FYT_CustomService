<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Command action" />

    <EditText
        android:id="@+id/editAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="dev.igor.fytcustomservice.ACTION_COMMAND"
        android:inputType="text" />

    <Switch
        android:id="@+id/switchAutostart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Autostart on boot" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="ACC ON play delay (ms)" />

    <EditText
        android:id="@+id/editAccOnDelayMs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="2000"
        android:inputType="number" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Fallback player package if no last player on ACCON" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iconFallbackPlayer"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/textFallbackPlayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="-"
            android:textColor="?android:textColorPrimary"
            android:textSize="16sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnPickFallbackPlayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pick fallback player app" />

</LinearLayout>
