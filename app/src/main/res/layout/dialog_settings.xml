<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Command action" />

    <EditText
        android:id="@+id/editAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="dev.igor.fytcustomservice.ACTION_COMMAND"
        android:inputType="text" />

    <Switch
        android:id="@+id/switchAutostart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Autostart on boot" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="ACC ON play delay (ms)" />

    <EditText
        android:id="@+id/editAccOnDelayMs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="2000"
        android:inputType="number" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Fallback player package if no last player on ACCON" />

    <EditText
        android:id="@+id/editFallbackPlayerPackage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="com.example.player"
        android:inputType="text" />

    <Button
        android:id="@+id/btnPickFallbackPlayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pick fallback player app" />

</LinearLayout>
